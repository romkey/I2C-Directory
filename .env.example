# Copy to .env for local development (docker-compose.dev.yml reads it).

# --- Database (dev/test connect to the Dockerized postgresql service) ---
# DATABASE_HOST=postgresql
# DATABASE_USERNAME=postgres
# DATABASE_PASSWORD=

# Production uses a full connection URL instead:
# DATABASE_URL=postgres://user:password@host:5432/i2capp_production

# --- Redis (Sidekiq + Action Cable + cache) ---
REDIS_URL=redis://redis:6379/0

# --- Rails ---
# Required in production:
# SECRET_KEY_BASE=
# APP_VERSION is injected from the git tag by CI.

# Devise token signing (optional; falls back to secret_key_base):
# DEVISE_SECRET_KEY=

# --- Outbound email (Mailgun SMTP, production) ---
# MAILGUN_SMTP_SERVER=smtp.mailgun.org
# MAILGUN_SMTP_PORT=587
# MAILGUN_DOMAIN=
# MAILGUN_SMTP_LOGIN=
# MAILGUN_SMTP_PASSWORD=

# --- Google Custom Search (datasheet/driver suggestion jobs) ---
# GOOGLE_CUSTOM_SEARCH_API_KEY=
# GOOGLE_CUSTOM_SEARCH_ENGINE_ID=
