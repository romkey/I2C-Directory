# Lightweight image for running RuboCop (rubocop-rails-omakase) in CI and locally.
FROM ruby:4.0.5-slim

RUN apt-get update -qq && \
    apt-get install --no-install-recommends -y build-essential git && \
    rm -rf /var/lib/apt/lists /var/cache/apt/archives && \
    gem install rubocop-rails-omakase --no-document

WORKDIR /rails

ENTRYPOINT ["rubocop"]
